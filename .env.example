# Online PvP (optional) — Supabase Realtime, no database or auth needed.
# Copy this file to `.env.local` and fill in values from a free Supabase project:
#   https://supabase.com → New project → Settings → API
# `.env.local` is gitignored. Restart `npm run dev` after changing it.
# On Vercel, add these same two vars under Project → Settings → Environment Variables.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
